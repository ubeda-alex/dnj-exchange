# DNJ Exchange — Variables de Entorno
# Copia este archivo como .env y completa los valores

# PostgreSQL
POSTGRES_DB=dnjexchange
POSTGRES_USER=dnj
POSTGRES_PASSWORD=cambia_esto_en_produccion

# VAPID Keys para Web Push (genera con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:tu@email.com
